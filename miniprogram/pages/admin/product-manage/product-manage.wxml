<view class="page">
  <!-- 无权限提示 -->
  <view class="no-auth" wx:if="{{noAuth}}">
    <text class="no-auth-text">无权限访问</text>
  </view>

  <block wx:else>
    <!-- 商品列表 -->
    <view class="list">
      <view class="prod card" wx:for="{{products}}" wx:key="_id">
        <image class="prod-image" src="{{item.images[0]}}" mode="aspectFill" wx:if="{{item.images.length > 0}}" />
        <view class="prod-image placeholder" wx:else>无图</view>
        <view class="prod-main">
          <view class="prod-name">{{item.name}}</view>
          <view class="prod-cat">{{item.category}}</view>
          <view class="prod-status {{item.status === 'on' ? 'on' : 'off'}}" data-id="{{item._id}}" data-status="{{item.status}}" bindtap="onToggleStatus">
            {{item.status === 'on' ? '已上架' : '已下架'}}
          </view>
        </view>
        <view class="prod-ops">
          <view class="op-edit" data-id="{{item._id}}" bindtap="onEdit">编辑</view>
          <view class="op-del" data-id="{{item._id}}" bindtap="onDelete">删除</view>
        </view>
      </view>
    </view>

    <view class="add-btn" bindtap="onAdd">+ 新增商品</view>

    <!-- 表单弹层 -->
    <view class="mask" wx:if="{{showForm}}" bindtap="onCancel">
      <view class="form" catchtap="noop">
        <view class="form-title">{{editingId ? '编辑商品' : '新增商品'}}</view>

        <view class="field">
          <text class="label">商品名</text>
          <input class="input" value="{{form.name}}" placeholder="如 糖炒栗子" data-field="name" bindinput="onFormInput" />
        </view>

        <view class="field">
          <text class="label">分类</text>
          <picker mode="selector" range="{{categories}}" value="{{categoryIndex}}" bindchange="onCategoryChange">
            <view class="picker">{{form.category}}</view>
          </picker>
        </view>

        <view class="field">
          <text class="label">简介</text>
          <textarea class="textarea" value="{{form.description}}" placeholder="工艺/卖点说明" data-field="description" bindinput="onFormInput" />
        </view>

        <view class="field">
          <text class="label">规格(每行)</text>
          <textarea class="textarea" value="{{form.specsText}}" placeholder="格式：规格名,价格,标签&#10;例：500g,28,现货" data-field="specsText" bindinput="onFormInput" />
        </view>

        <view class="field">
          <text class="label">排序</text>
          <input class="input" type="number" value="{{form.sortOrder}}" placeholder="越小越靠前" data-field="sortOrder" bindinput="onFormInput" />
        </view>

        <view class="field">
          <text class="label">上架</text>
          <switch checked="{{form.status === 'on'}}" bindchange="onStatusChange" />
        </view>

        <view class="field">
          <text class="label">图片</text>
          <view class="img-row">
            <image wx:for="{{form.images}}" wx:key="*this" class="img-thumb" src="{{item}}" mode="aspectFill">
              <view class="img-del" catchtap="onRemoveImage" data-index="{{index}}">✕</view>
            </image>
            <view class="img-add" bindtap="onChooseImage">+</view>
          </view>
        </view>

        <view class="form-actions">
          <view class="btn-cancel" bindtap="onCancel">取消</view>
          <view class="btn-submit" bindtap="onSubmit">保存</view>
        </view>
      </view>
    </view>
  </block>
</view>
