.page {
  min-height: 100vh;
  background-color: var(--color-bg);
  padding: 24rpx;
}

.no-auth {
  padding-top: 300rpx;
  text-align: center;
}

.no-auth-text {
  font-size: 32rpx;
  color: #999999;
}

.list {
  padding-bottom: 120rpx;
}

.prod {
  display: flex;
  align-items: center;
  padding: 16rpx;
  margin-bottom: 16rpx;
}

.prod-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.prod-image.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #eeeeee;
  color: #999999;
  font-size: 22rpx;
}

.prod-main {
  flex: 1;
  margin-left: 16rpx;
}

.prod-name {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.prod-cat {
  font-size: 24rpx;
  color: #999999;
  margin-top: 6rpx;
}

.prod-status {
  display: inline-block;
  margin-top: 10rpx;
  font-size: 22rpx;
  padding: 2rpx 16rpx;
  border-radius: 20rpx;
}

.prod-status.on {
  color: #ffffff;
  background-color: #4CAF50;
}

.prod-status.off {
  color: #ffffff;
  background-color: #bbbbbb;
}

.prod-ops {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.op-edit,
.op-del {
  font-size: 26rpx;
  padding: 8rpx 20rpx;
}

.op-edit {
  color: var(--color-primary);
}

.op-del {
  color: #e74c3c;
  margin-top: 16rpx;
}

.add-btn {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  background-color: var(--color-primary);
  color: #ffffff;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 12rpx;
  font-size: 30rpx;
}

/* 表单弹层 */
.mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 50;
}

.form {
  width: 100%;
  background-color: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx;
  max-height: 86vh;
  overflow-y: auto;
}

.form-title {
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 24rpx;
}

.field {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.label {
  width: 140rpx;
  font-size: 26rpx;
  color: #666666;
  padding-top: 12rpx;
  flex-shrink: 0;
}

.input,
.textarea,
.picker {
  flex: 1;
  background-color: #f7f7f7;
  border-radius: 8rpx;
  padding: 16rpx;
  font-size: 26rpx;
  color: #333333;
}

.textarea {
  height: 120rpx;
}

.img-row {
  flex: 1;
  display: flex;
  flex-wrap: wrap;
}

.img-thumb {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  margin: 0 12rpx 12rpx 0;
}

.img-del {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  background-color: rgba(0, 0, 0, 0.6);
  color: #fff;
  border-radius: 50%;
  font-size: 20rpx;
}

.img-add {
  width: 120rpx;
  height: 120rpx;
  line-height: 120rpx;
  text-align: center;
  border: 2rpx dashed #cccccc;
  border-radius: 8rpx;
  color: #999999;
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.form-actions {
  display: flex;
  margin-top: 16rpx;
}

.btn-cancel,
.btn-submit {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  border-radius: 40rpx;
  font-size: 30rpx;
  margin: 0 12rpx;
}

.btn-cancel {
  border: 2rpx solid #cccccc;
  color: #666666;
}

.btn-submit {
  background-color: var(--color-primary);
  color: #ffffff;
}
