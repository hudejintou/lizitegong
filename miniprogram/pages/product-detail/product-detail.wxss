.page {
  min-height: 100vh;
  background-color: var(--color-bg);
  padding-bottom: 140rpx;
}

/* 轮播 */
.gallery {
  width: 100%;
  height: 600rpx;
  background-color: #eeeeee;
}

.gallery-image {
  width: 100%;
  height: 600rpx;
  display: block;
}

.gallery-image.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999999;
  font-size: 28rpx;
}

/* 卡片 */
.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 16rpx;
}

.name {
  font-size: 34rpx;
  font-weight: bold;
  color: #333333;
}

.desc {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #888888;
  line-height: 38rpx;
}

.section-title {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 16rpx;
}

/* 规格选择 */
.spec-list {
  display: flex;
  flex-wrap: wrap;
}

.spec-item {
  position: relative;
  border: 2rpx solid #dddddd;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  margin: 0 16rpx 16rpx 0;
  text-align: center;
}

.spec-item.active {
  border-color: var(--color-primary);
  background-color: rgba(139, 69, 19, 0.06);
}

.spec-name {
  font-size: 28rpx;
  color: #333333;
}

.spec-price {
  font-size: 26rpx;
  color: var(--color-primary);
  margin-top: 6rpx;
}

.spec-tag {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  background-color: var(--color-secondary);
  color: #ffffff;
  font-size: 18rpx;
  padding: 2rpx 8rpx;
  border-radius: 8rpx;
}

/* 数量步进器 */
.stepper {
  display: flex;
  align-items: center;
}

.step-btn {
  width: 64rpx;
  height: 64rpx;
  line-height: 60rpx;
  text-align: center;
  border: 2rpx solid #dddddd;
  font-size: 36rpx;
  color: #333333;
}

.step-num {
  width: 96rpx;
  text-align: center;
  font-size: 30rpx;
}

/* 底部操作栏 */
.footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background-color: #ffffff;
  border-top: 1rpx solid #eeeeee;
}

.subtotal {
  font-size: 28rpx;
  color: #333333;
}

.subtotal .price {
  font-size: 36rpx;
}

.actions {
  display: flex;
}

.btn-add,
.btn-checkout {
  padding: 18rpx 28rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  text-align: center;
  margin-left: 16rpx;
}

.btn-add {
  border: 2rpx solid var(--color-primary);
  color: var(--color-primary);
}

.btn-checkout {
  background-color: var(--color-primary);
  color: #ffffff;
}

/* 加载中 */
.loading {
  padding-top: 200rpx;
  text-align: center;
  color: #999999;
  font-size: 28rpx;
}
