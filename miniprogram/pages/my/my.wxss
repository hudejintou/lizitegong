.page {
  min-height: 100vh;
  background-color: var(--color-bg);
  padding: 24rpx;
}

.block {
  margin-bottom: 24rpx;
}

.block-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
}

.wechat-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.wechat-id {
  font-size: 28rpx;
  color: #333333;
}

.copy-btn {
  font-size: 26rpx;
  color: #ffffff;
  background-color: var(--color-primary);
  padding: 8rpx 28rpx;
  border-radius: 28rpx;
}

.empty-text {
  color: #999999;
  font-size: 26rpx;
}

.history-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.history-item:last-child {
  border-bottom: none;
}

.history-no {
  font-size: 28rpx;
  color: #333333;
}

.history-meta {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

.history-rebuy {
  font-size: 28rpx;
  color: var(--color-primary);
}
