<view class="page">
  <view class="block card">
    <view class="block-title">联系店主</view>
    <view class="wechat-row" bindtap="onCopyWechat">
      <text class="wechat-id">{{shopWechat || '暂未配置'}}</text>
      <text class="copy-btn">复制</text>
    </view>
  </view>

  <view class="block card">
    <view class="block-title">历史清单</view>
    <view wx:if="{{history.length === 0}}" class="empty-text">暂无历史清单</view>
    <view class="history-item" wx:for="{{history}}" wx:key="orderNo"
          data-index="{{index}}" bindtap="onHistoryTap">
      <view class="history-left">
        <view class="history-no">订单 {{item.orderNo}}</view>
        <view class="history-meta">{{item.items.length}} 件商品 · 合计 ¥{{item.totalAmount}}</view>
      </view>
      <view class="history-rebuy">复购 ›</view>
    </view>
  </view>
</view>
