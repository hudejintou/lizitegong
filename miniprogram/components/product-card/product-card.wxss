.card {
  width: 340rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-image-wrap {
  width: 100%;
  height: 340rpx;
}

.card-image {
  width: 100%;
  height: 340rpx;
  display: block;
}

.card-image.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #eeeeee;
  color: #999999;
  font-size: 24rpx;
}

.card-body {
  padding: 16rpx;
}

.card-name {
  font-size: 28rpx;
  color: #333333;
  line-height: 36rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.card-price {
  margin-top: 12rpx;
  text-align: right;
  font-size: 30rpx;
}
